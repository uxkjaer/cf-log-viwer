{
  "name": "cf-log-viewer",
  "version": "1.0.0",
  "description": "A local web-based viewer for Cloud Foundry application logs with structured JSON parsing, filtering, and drill-down.",
  "main": "bin/cf-log-viewer.js",
  "bin": {
    "cf-log-viewer": "./bin/cf-log-viewer.js"
  },
  "scripts": {
    "start": "bun run bin/cf-log-viewer.js",
    "build": "bun build bin/cf-log-viewer.js --compile --outfile dist/cf-log-viewer",
    "build:linux-x64": "bun build bin/cf-log-viewer.js --compile --target=bun-linux-x64 --outfile dist/cf-log-viewer-linux-x64",
    "build:linux-arm64": "bun build bin/cf-log-viewer.js --compile --target=bun-linux-arm64 --outfile dist/cf-log-viewer-linux-arm64",
    "build:darwin-x64": "bun build bin/cf-log-viewer.js --compile --target=bun-darwin-x64 --outfile dist/cf-log-viewer-darwin-x64",
    "build:darwin-arm64": "bun build bin/cf-log-viewer.js --compile --target=bun-darwin-arm64 --outfile dist/cf-log-viewer-darwin-arm64",
    "build:windows-x64": "bun build bin/cf-log-viewer.js --compile --target=bun-windows-x64 --outfile dist/cf-log-viewer-windows-x64.exe"
  },
  "keywords": [
    "cloud-foundry",
    "cf",
    "logs",
    "viewer",
    "cap",
    "sap",
    "bun"
  ],
  "license": "MIT"
}
